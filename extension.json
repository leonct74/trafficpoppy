{
  "id": "com.trafficpoppy.desktop",
  "name": "TrafficPoppy",
  "version": "0.1.0",
  "description": "Privacy-first web analytics that run entirely in your own AWS — a 1 KB script tag, no cookies, no banners, and nobody in the data path but you.",
  "icon": "frontend/trafficpoppy-icon.png",
  "permissionSet": {
    "id": "trafficpoppy-backend",
    "name": "TrafficPoppy backend",
    "description": "Deploys and removes its own CloudFormation stack (named TrafficPoppyStack): a DynamoDB table, a collector Lambda behind a public URL, and a least-privilege execution role for that Lambda. Every change and delete is limited to resources named TrafficPoppy* (and a trafficpoppy-deploy-* code bucket) — it cannot touch anything else in your account. It creates one narrowly-scoped IAM role for its own Lambda; no account or organisation access.",
    "requiredTags": ["agentspoppy:account", "agentspoppy:app", "agentspoppy:connection"],
    "grants": [
      {
        "service": "cloudformation",
        "actions": [
          "CreateStack",
          "UpdateStack",
          "ContinueUpdateRollback",
          "DeleteStack",
          "DescribeStacks",
          "DescribeStackEvents",
          "DescribeStackResources"
        ],
        "resourceScope": "arn:aws:cloudformation:*:*:stack/TrafficPoppyStack/*"
      },
      {
        "service": "dynamodb",
        "actions": [
          "CreateTable",
          "DeleteTable",
          "DescribeTable",
          "UpdateTimeToLive",
          "DescribeTimeToLive",
          "TagResource",
          "ListTagsOfResource",
          "Query",
          "GetItem",
          "PutItem",
          "DeleteItem"
        ],
        "resourceScope": "arn:aws:dynamodb:*:*:table/TrafficPoppy*"
      },
      {
        "service": "lambda",
        "actions": [
          "CreateFunction",
          "DeleteFunction",
          "GetFunction",
          "UpdateFunctionCode",
          "UpdateFunctionConfiguration",
          "CreateFunctionUrlConfig",
          "DeleteFunctionUrlConfig",
          "GetFunctionUrlConfig",
          "AddPermission",
          "RemovePermission",
          "GetPolicy",
          "TagResource",
          "ListTags"
        ],
        "resourceScope": "arn:aws:lambda:*:*:function:TrafficPoppy*"
      },
      {
        "service": "iam",
        "actions": [
          "CreateRole",
          "DeleteRole",
          "GetRole",
          "PassRole",
          "PutRolePolicy",
          "DeleteRolePolicy",
          "GetRolePolicy",
          "TagRole",
          "ListRoleTags"
        ],
        "resourceScope": "arn:aws:iam::*:role/TrafficPoppy*"
      },
      {
        "service": "logs",
        "actions": ["CreateLogGroup", "DeleteLogGroup", "PutRetentionPolicy", "TagResource", "ListTagsForResource"],
        "resourceScope": "arn:aws:logs:*:*:log-group:/aws/lambda/TrafficPoppy*"
      },
      {
        "service": "s3",
        "actions": ["CreateBucket", "DeleteBucket", "ListBucket", "PutBucketTagging", "GetBucketLocation"],
        "resourceScope": "arn:aws:s3:::trafficpoppy-deploy-*"
      },
      {
        "service": "s3",
        "actions": ["PutObject", "GetObject", "DeleteObject"],
        "resourceScope": "arn:aws:s3:::trafficpoppy-deploy-*/*"
      }
    ],
    "limits": null
  },
  "frontend": {
    "entry": "frontend/index.html"
  },
  "backend": {
    "entry": "backend/trafficpoppy-sidecar",
    "transport": "http"
  },
  "teardown": {
    "endpoint": "/teardown"
  },
  "capabilities": ["aws:credentials", "connection:read", "backend:invoke"]
}
